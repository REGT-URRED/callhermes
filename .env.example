# === CallHermes - Configuración ===

# Hermes API Server (OpenAI-compatible)
HERMES_API_URL=http://localhost:8642/v1
HERMES_API_KEY=tu-api-key-aqui
HERMES_MODEL=hermes-agent
HERMES_TIMEOUT=60

# Servidor web
HOST=0.0.0.0
PORT=3000

# STT (Speech-to-Text) - Dejar vacío = auto-detect
# Si hay GPU → medium + float16 + cuda
# Si no hay GPU → base + int8 + cpu
WHISPER_MODEL=
WHISPER_DEVICE=
WHISPER_COMPUTE=

# TTS (Text-to-Speech)
TTS_VOICE=es-AR-ElenaNeural
TTS_TIMEOUT=120

# Límites de audio
MAX_AUDIO_BYTES=52428800
MIN_AUDIO_BYTES=100
